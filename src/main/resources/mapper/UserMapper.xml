<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.hakimi.aviation.mapper.UserMapper">

    <insert id="register" keyColumn="id">
        insert into `user` (user_name,email,password,avatar)
        values (#{userName,jdbcType=VARCHAR},
                #{email,jdbcType=VARCHAR},
                #{password,jdbcType=VARCHAR},
                #{avatar,jdbcType=VARCHAR})
    </insert>

    <select id="findUserById" resultType="com.hakimi.aviation.entity.User">
        SELECT * FROM `user` WHERE `id` = #{user_id}
    </select>

    <select id="findUserByEmailAndPwd" resultType="com.hakimi.aviation.entity.User">
        SELECT * FROM `user` WHERE `email` = #{email} AND `password` = #{password}
    </select>

</mapper>